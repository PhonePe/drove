{{#partial "content"}}
    <section>
        <div class="row">
            <div class="col">
                <h4 class="fw-bold">Cluster — Executors</h4>
            </div>
        </div>
        <div class="row">
            <div class="col">
                <table class="table table-bordered" id="executors" style="width: 100%">
                    <thead>
                    <tr>
                        <th data-priority="11000">ID</th>
                        <th>Host</th>
                        <th>State</th>
                        <th>Free Cores</th>
                        <th>Used Cores</th>
                        <th>Free Memory</th>
                        <th>Used Memory</th>
                        <th data-priority="10500">Tags</th>
                    </tr>
                    </thead>
                </table>
            </div>
        </div>
    </section>
{{/partial}}

{{#partial "page_js"}}
    const executors = $('#executors').DataTable({
        processing: true,
        ajax: '/apis/v1/cluster/executors',
        paging: true,
        info: false,
        responsive: false,
        scrollX: true,
        columnDefs: [
            {
                className: 'text-center',
                targets: [2, 3, 4, 5]
            }
        ],
        columns: [
            {
                data: 'executorId',
                render: function(data, type, row, meta) {
                    if(type === 'display') {
                        const link = '<a href="/executors/{0}" class="fw-semibold">{1}</a>'.format(row.executorId, row.executorId);
                        return (row.state == 'REMOVED' || row.state == 'BLACKLISTED')
                            ? '<del>{0}</del>'.format(link)
                            : link;
                    }
                    return data;
                }
            },
            { data: 'hostname' },
            { data: 'state', render: tableExecutorStateText },
            { data: 'freeCores' },
            { data: 'usedCores' },
            { data: 'freeMemory', render: tableBytesText },
            { data: 'usedMemory', render: tableBytesText },
            {
                data: 'tags',
                render: function(data, type, row, meta) {
                    if(type === 'sort') {
                        return data.join(',');
                    }
                    var tagStr = "";
                    if(!data) {
                       return tagStr;
                    }
                    data.sort();
                    for(var i = 0; i < data.length; i++) {
                       tagStr += '<span class="badge bg-secondary text-wrap">' + data[i] + '</span> ';
                    }
                    return tagStr;
                }
            }
        ]
    });

    setInterval(() => {
        executors.ajax.reload(null, false);
    }, 5000);
{{/partial}}
{{> common/base}}
