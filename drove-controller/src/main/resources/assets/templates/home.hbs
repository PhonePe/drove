{{#partial "page_js"}}
    // ── Dashboard stat cards ────────────────────────────────────────────
    function refreshDashboardCards() {
        $.getJSON('/apis/v1/cluster', function(resp) {
            if (!resp || resp.status !== 'SUCCESS') return;
            const d = resp.data;

            // Cluster state
            const stateColors = { NORMAL: 'success', MAINTENANCE: 'warning', LOST: 'danger' };
            const sc = stateColors[d.state] || 'secondary';
            $('#dash-state').html('<span class="badge bg-' + sc + ' fw-bold fs-6">' + d.state + '</span>');
            const leaderEl = $('#dash-leader');
            leaderEl.text(d.leader).attr('title', d.leader);

            // Executors
            $('#dash-executors').text(d.numExecutors);

            // CPU
            const cpuPct = d.totalCores > 0 ? Math.round(d.usedCores / d.totalCores * 100) : 0;
            const cpuTheme = cpuPct >= 80 ? 'danger' : cpuPct >= 60 ? 'warning' : 'success';
            $('#dash-cpu-text').text(d.usedCores + ' / ' + d.totalCores);
            $('#dash-cpu-bar').attr('class', 'progress-bar bg-' + cpuTheme).css('width', cpuPct + '%');
            $('#dash-cpu-free').text(d.freeCores + ' free');

            // Memory
            const memPct = d.totalMemory > 0 ? Math.round(d.usedMemory / d.totalMemory * 100) : 0;
            const memTheme = memPct >= 80 ? 'danger' : memPct >= 60 ? 'warning' : 'success';
            $('#dash-mem-text').text(bytesToString(d.usedMemory) + ' / ' + bytesToString(d.totalMemory));
            $('#dash-mem-bar').attr('class', 'progress-bar bg-' + memTheme).css('width', memPct + '%');
            $('#dash-mem-free').text(bytesToString(d.freeMemory) + ' free');

            // Applications
            $('#dash-apps-active').text(d.numActiveApplications);
            $('#dash-apps-total').text('of ' + d.numApplications + ' total');
            const appPct = d.numApplications > 0 ? Math.round(d.numActiveApplications / d.numApplications * 100) : 0;
            $('#dash-apps-bar').css('width', appPct + '%');

            // Tasks
            $('#dash-tasks').text(d.numActiveTasks);

            // Local Services
            $('#dash-svc-active').text(d.numActiveLocalServices);
            $('#dash-svc-total').text('of ' + d.numLocalServices + ' svc');
        });
    }
    refreshDashboardCards();

    // ── Applications mini-table ─────────────────────────────────────────
    const dashApps = $('#dash-applications').DataTable({
        processing: true,
        ajax: {
            url: '/apis/v1/applications',
            dataSrc: function(res) {
                return res.data ? Object.keys(res.data).map(key => res.data[key]) : [];
            }
        },
        paging: false,
        searching: false,
        info: false,
        columnDefs: [{ className: 'text-center text-wrap', targets: '_all' }],
        columns: [
            {
                data: 'id',
                render: function(data, type, row, meta) {
                    return '<a href="/applications/' + data + '" class="fw-bold">' + data + '</a>';
                }
            },
            { data: 'name' },
            { data: 'state', render: tableAppStateText },
            { data: 'requiredInstances' },
            { data: 'healthyInstances' },
            { data: 'totalCPUs' },
            { data: 'totalMemory', render: tableBytesText }
        ]
    });

    // ── Executors mini-table ────────────────────────────────────────────
    const dashExecs = $('#dash-executors-table').DataTable({
        processing: true,
        ajax: '/apis/v1/cluster/executors',
        paging: false,
        searching: false,
        info: false,
        responsive: false,
        scrollX: true,
        columnDefs: [{ className: 'text-center', targets: [2, 3, 4, 5, 6] }],
        columns: [
            {
                data: 'executorId',
                render: function(data, type, row, meta) {
                    if (type === 'display') {
                        const link = '<a href="/executors/{0}" class="fw-semibold">{1}</a>'.format(row.executorId, row.executorId);
                        return (row.state === 'REMOVED' || row.state === 'BLACKLISTED')
                            ? '<del>' + link + '</del>'
                            : link;
                    }
                    return data;
                }
            },
            { data: 'hostname' },
            { data: 'state', render: tableExecutorStateText },
            { data: 'freeCores' },
            { data: 'usedCores' },
            { data: 'freeMemory', render: tableBytesText },
            { data: 'usedMemory', render: tableBytesText },
            {
                data: 'tags',
                render: function(data, type, row, meta) {
                    if (type === 'sort') return data ? data.join(',') : '';
                    if (!data) return '';
                    return data.sort().map(t => '<span class="badge bg-secondary text-wrap">' + t + '</span>').join(' ');
                }
            }
        ]
    });

    // ── Auto-refresh every 10 s ─────────────────────────────────────────
    setInterval(function() {
        refreshDashboardCards();
        dashApps.ajax.reload(null, false);
        dashExecs.ajax.reload(null, false);
    }, 10000);
