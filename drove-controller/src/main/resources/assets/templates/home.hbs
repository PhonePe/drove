{{#partial "page_js"}}
    const FIXED_ROW_COUNT = 5;

    function refreshDashboard() {
        $.getJSON('/apis/v1/cluster/dashboard', function(resp) {
            if (!resp || resp.status !== 'SUCCESS') {
                return;
            }
            refreshDashboardCards(resp.data.clusterSummary);
            renderAppsSection(resp.data.appStats);
            renderTasksSection(resp.data.taskStats);
            renderLocalServicesSection(resp.data.serviceStats);
            renderExecutorSection(resp.data.executorStats);
        });
    }

    function refreshDashboardCards(d) {

        // Cluster state
        const sc = clusterStateColour(d.state);
        $('#dash-state')
            .html('<span class="badge bg-' + sc + ' fw-bold fs-6">' + d.state + '</span>');
        const leaderEl = $('#dash-leader');
        leaderEl.text(d.leader).attr('title', d.leader);

        // Executors
        $('#dash-executors').text(d.numExecutors);

        // CPU
        $('#dash-cpu-text').text(d.usedCores + ' / ' + d.totalCores);
        updateProgress('#dash-cpu-bar', d.usedCores, 0, d.totalCores);
        $('#dash-cpu-free').text(d.freeCores + ' free');

        // Memory
        $('#dash-mem-text').text(bytesToString(d.usedMemory) + ' / ' + bytesToString(d.totalMemory));
        updateProgress('#dash-mem-bar', d.usedMemory, 0, d.totalMemory);
        $('#dash-mem-free').text(bytesToString(d.freeMemory) + ' free');

        // Applications
        $('#dash-apps-active').text(d.numActiveApplications);
        $('#dash-apps-total').text('of ' + d.numApplications + ' total');
        const appPct = d.numApplications > 0 ? Math.round(d.numActiveApplications / d.numApplications * 100) : 0;
        $('#dash-apps-bar').css('width', appPct + '%');

        // Tasks
        $('#dash-tasks').text(d.numActiveTasks);

        // Local Services
        $('#dash-svc-active').text(d.numActiveLocalServices);
        $('#dash-svc-total').text('of ' + d.numLocalServices + ' svc');
    }

    function renderAppsSection(appStats) {
        renderAppInstancesCounts(appStats);
        renderAppsStateCount(appStats);
        dashApps.clear().rows.add(appStats.topApps).draw();
    }

    function renderTasksSection(taskStats) {
        renderTaskCount(taskStats);
        renderTasksStateCount(taskStats);
        dashTasks.clear().rows.add(updateResourceUsage(taskStats.topTasks)).draw();
    }

    function renderLocalServicesSection(svcStats) {
        renderLocalServicesCount(svcStats);
        renderLocalServicesStateCount(svcStats);
        dashLocalServices.clear().rows.add(svcStats.topServices).draw();
    }

    function renderExecutorSection(executorStats) {
        renderExecutorStateCount(executorStats);
        const utilization = executorStats.utilization;
        $('#dash-executor-balance')
            .text(utilization.balanceScore.toFixed(2).toString());
        renderExecutorUtilization(executorStats);
    }

    function zeroFillExecutorStateCount() {
        const parent = $('#executors-by-state');
        updateStateCount(parent, 'executor-total', '-', 'Total', 'body');
        updateStateCount(parent, 'executor-active', '-', 'Active', 'success');
        updateStateCount(parent, 'executor-blacklisting', '-', 'Blacklisting', 'warning');
        updateStateCount(parent, 'executor-blacklisted', '-', 'Blacklisted', 'danger');
        updateStateCount(parent, 'executor-unready', '-', 'Unready', 'info');
        updateStateCount(parent, 'executor-removed', '-', 'Removed', 'secondary');
    }

    function renderExecutorStateCount(executorStats) {
        const countByState = executorStats.executorCountByState;
        const active = get(countByState, 'ACTIVE');
        const blacklisting = get(countByState, 'BLACKLIST_REQUESTED');
        const blacklisted = get(countByState, 'BLACKLISTED');
        const unready = get(countByState, 'UNREADY');
        const removed = get(countByState, 'REMOVED');
        const total = Object.values(countByState).reduce((a, b) => a + b, 0);

        const parent = $('#executors-by-state');
        updateStateCount(parent, 'executor-total', total, 'Total', 'body');
        updateStateCount(parent, 'executor-active', active, 'Active', 'success');
        updateStateCount(parent, 'executor-blacklisting', blacklisting, 'Blacklisting', 'warning');
        updateStateCount(parent, 'executor-blacklisted', blacklisted, 'Blacklisted', 'danger');
        updateStateCount(parent, 'executor-unready', unready, 'Unready', 'info');
        updateStateCount(parent, 'executor-removed', removed, 'Removed', 'secondary');
    }

    function zeroFillExecutorUtilization() {
        const parent = $('#executor-utilization');
        updateStateCount(parent, 'utilization-mean', '-', 'Average Utilization', 'body');
        updateStateCount(parent, 'utilization-max', '-', 'Highest Utilization', 'body');
        updateStateCount(parent, 'utilization-min', '-', 'Lowest Utilization', 'body');
    }

    function renderExecutorUtilization(executorStats) {
        const utilization = executorStats.utilization;
        const parent = $('#executor-utilization');
        updateStateCount(parent, 'utilization-mean',
            (utilization.averageUtilization * 100).toFixed(2) + '%', 'Average Utilization', 'body');
        updateStateCount(parent, 'utilization-max',
            (utilization.highestUtilization * 100).toFixed(2) + '%', 'Highest Utilization', 'body');
        updateStateCount(parent, 'utilization-min',
            (utilization.lowestUtilization * 100).toFixed(2) + '%', 'Lowest Utilization', 'body');
    }

    function renderAppInstancesCounts(appStats) {
        $('#dash-app-instances-active').text(appStats.totalHealthyInstances.toString());
    }

    function renderTaskCount(taskStats) {
        $('#dash-tasks').text(get(taskStats.taskCountByState, 'RUNNING').toString());
    }

    function renderLocalServicesCount(svcStats) {
        $('#dash-local-services').text(svcStats.totalHealthyInstances.toString());
    }

    function zeroFillAppStateCount() {
        const parent = $('#apps-by-state');
        updateStateCount(parent, 'apps-total', '-', 'Total', 'body');
        updateStateCount(parent, 'apps-running', '-', 'Running', 'success');
        updateStateCount(parent, 'apps-outage', '-', 'Outage', 'danger');
        updateStateCount(parent, 'apps-scaling', '-', 'Scaling', 'warning');
        updateStateCount(parent, 'apps-restarting', '-', 'Restarting', 'info');
        updateStateCount(parent, 'apps-paused', '-', 'Paused', 'secondary');
    }

    function renderAppsStateCount(appStats) {
        const countByState = appStats.appCountByState;
        const running = get(countByState, 'RUNNING');
        const outage = get(countByState, 'OUTAGE_DETECTED');
        const scaling = get(countByState, 'SCALING_REQUESTED')
                + get(countByState, 'STOP_INSTANCES_REQUESTED')
                + get(countByState, 'DESTROY_REQUESTED');
        const restarting = get(countByState, 'REPLACE_INSTANCES_REQUESTED');
        const paused = get(countByState, 'MONITORING') + get(countByState, 'INIT');
        const total = Object.values(countByState).reduce((a, b) => a + b, 0);

        const parent = $('#apps-by-state');
        updateStateCount(parent, 'apps-total', total, 'Total', 'body');
        updateStateCount(parent, 'apps-running', running, 'Running', 'success');
        updateStateCount(parent, 'apps-outage', outage, 'Outage', 'danger');
        updateStateCount(parent, 'apps-scaling', scaling, 'Scaling', 'warning');
        updateStateCount(parent, 'apps-restarting', restarting, 'Restarting', 'info');
        updateStateCount(parent, 'apps-paused', paused, 'Paused', 'secondary');
    }

    function zeroFillTaskStateCount() {
        const parent = $('#tasks-by-state');
        updateStateCount(parent, 'tasks-total', '-', 'Total', 'body');
        updateStateCount(parent, 'tasks-running', '-', 'Running', 'success');
        updateStateCount(parent, 'tasks-failed', '-', 'Failed', 'danger');
        updateStateCount(parent, 'tasks-starting', '-', 'Starting', 'warning');
        updateStateCount(parent, 'tasks-pending', '-', 'Pending', 'info');
        updateStateCount(parent, 'tasks-completed', '-', 'Completed', 'secondary');
    }

    function renderTasksStateCount(taskStats) {
        const countByState = taskStats.taskCountByState;
        const running = get(countByState, 'RUNNING');
        const pending = get(countByState, 'PENDING');
        const starting = get(countByState, 'PROVISIONING')
                + get(countByState, 'STARTING');
        const completed = get(countByState, 'RUN_COMPLETED')
                + get(countByState, 'DEPROVISIONING')
                + get(countByState, 'STOPPED');
        const failed = get(countByState, 'RUN_FAILED')
                + get(countByState, 'PROVISIONING_FAILED')
                + get(countByState, 'LOST');
        const total = Object.values(countByState).reduce((a, b) => a + b, 0);
        
        const parent = $('#tasks-by-state');
        updateStateCount(parent, 'tasks-total', total, 'Total', 'body');
        updateStateCount(parent, 'tasks-running', running, 'Running', 'success');
        updateStateCount(parent, 'tasks-failed', failed, 'Failed', 'danger');
        updateStateCount(parent, 'tasks-starting', starting, 'Starting', 'warning');
        updateStateCount(parent, 'tasks-pending', pending, 'Pending', 'info');
        updateStateCount(parent, 'tasks-completed', completed, 'Completed', 'secondary');
    }

    function zeroFillLocalServicesStateCount() {
        const parent = $('#local-services-by-state');
        updateStateCount(parent, 'svc-total', '-', 'Total', 'body');
        updateStateCount(parent, 'svc-active', '-', 'Active', 'success');
        updateStateCount(parent, 'svc-testing', '-', 'Testing', 'primary');
        updateStateCount(parent, 'svc-deploying', '-', 'Deploying', 'warning');
        updateStateCount(parent, 'svc-stopping', '-', 'Stopping', 'info');
        updateStateCount(parent, 'svc-inactive', '-', 'Inactive', 'secondary');
    }

    function renderLocalServicesStateCount(svcStats) {
        const countByState = svcStats.serviceCountByState;
        const active = get(countByState, 'ACTIVE')
                + get(countByState, 'ACTIVATION_REQUESTED');
        const testing = get(countByState, 'CONFIG_TESTING')
                + get(countByState, 'CONFIG_TESTING_REQUESTED');
        const deploying = get(countByState, 'ADJUSTING_INSTANCES')
                + get(countByState, 'DEPLOYING_TEST_INSTANCE')
                + get(countByState, 'REPLACING_INSTANCES')
                + get(countByState, 'UPDATING_INSTANCES_COUNT');
        const stopping = get(countByState, 'STOPPING_INSTANCES')
                + get(countByState, 'EMERGENCY_DEACTIVATION_REQUESTED')
                + get(countByState, 'DESTROY_REQUESTED')
                + get(countByState, 'DESTROYED');
        const inactive = get(countByState, 'INACTIVE')
                + get(countByState, 'DEACTIVATION_REQUESTED')
                + get(countByState, 'INIT');
        const total = Object.values(countByState).reduce((a, b) => a + b, 0);

        const parent = $('#local-services-by-state');
        updateStateCount(parent, 'svc-total', total, 'Total', 'body');
        updateStateCount(parent, 'svc-active', active, 'Active', 'success');
        updateStateCount(parent, 'svc-testing', testing, 'Testing', 'primary');
        updateStateCount(parent, 'svc-deploying', deploying, 'Deploying', 'warning');
        updateStateCount(parent, 'svc-stopping', stopping, 'Stopping', 'info');
        updateStateCount(parent, 'svc-inactive', inactive, 'Inactive', 'secondary');
    }

    function updateStateCount(parent, name, count, displayText, colour) {
        if(parent.find('#element-by-state-row-' + name).length > 0) {
            parent.find('#element-by-state-row-' + name + ' .count-value')
            .text(count.toString());
            return;
        }
        const row = renderTemplateHtml('state-count',
            [{
                name: name,
                colour: colour,
                displayText: displayText,
                count: count.toString()
            }]);
        parent.append(row);
    }

    function get(map, key) {
        return map[key] || 0;
    } 

    zeroFillAppStateCount();
    zeroFillTaskStateCount();
    zeroFillLocalServicesStateCount();
    zeroFillExecutorStateCount();
    zeroFillExecutorUtilization();

    refreshDashboard();

    const dashApps = $('#dash-applications').DataTable({
        ordering: false,
        processing: true,
        paging: false,
        searching: false,
        info: false,
        columnDefs: [{ className: 'text-center text-wrap', targets: '_all' }],
        columns: [
            {
                data: 'id',
                render: function(data, type, row, meta) {
                    if ( type !== 'display' ) {
                        return data;
                    }
             
                    const dataLink = "/applications/{0}".format(data);
                    const colour = appStateColour(row.state);
                    const classes = "fw-bold border-start border-4 px-2 border-{0}"
                        .format(colour.colour);
                    return ellipsizedHtml(data, 10, dataLink, classes);
                }
            },
            {
                data: 'requiredInstances',
                render: function(data, type, row, meta) {
                    const healthy = row.healthyInstances || 0;
                    return healthy + ' / ' + data;
                }
            },
            { data: 'totalCPUs' },
            { data: 'totalMemory', render: tableBytesText }
        ],
        drawCallback: function(settings) {
            insertEmptyTable(settings, this, 5);
        }
    });

    const dashTasks = $('#tasks').DataTable({
        ordering: false,
        processing: true,
        paging: false,
        searching: false,
        info: false,
        columnDefs: [{ className: 'text-center text-wrap', targets: '_all' }],
        columns: [
            {
                data: 'sourceAppName',
                render: function(data, type, row, meta) {
                    if ( type !== 'display' ) {
                        return data;
                    }
             
                    const dataLink = "/tasks/{0}/{1}"
                        .format(row.sourceAppName, row.taskId);
                    const colour = appStateColour(row.state);
                    const classes = "fw-bold border-start border-4 px-2 border-{0}"
                        .format(colour.colour);
                    const text = row.sourceAppName + ' / ' + row.taskId;
                    return ellipsizedHtml(text, 15, dataLink, classes);
                }
            },
            { data: 'usedCores' },
            { data: 'usedMemory', render: tableBytesText },
            { data: 'created', render: tableAgeText }
        ],
        drawCallback: function(settings) {
            insertEmptyTable(settings, this, 5);
        }
    });

    const dashLocalServices = $('#localservices').DataTable({
        ordering: false,
        processing: true,
        paging: false,
        searching: false,
        info: false,
        columnDefs: [{ className: 'text-center text-wrap', targets: '_all' }],
        columns: [
            {
                data: 'id',
                render: function(data, type, row, meta) {
                    if ( type !== 'display' ) {
                        return data;
                    }
             
                    const dataLink = "/localservices/{0}".format(data);
                    const colour = localServiceStateColour(row.state);
                    const classes = "fw-bold border-start border-4 px-2 border-{0}"
                        .format(colour.colour);
                    return ellipsizedHtml(data, 10, dataLink, classes);
                }
            },
            { data: 'healthyInstances' },
            { data: 'totalCPUs' },
            { data: 'totalMemory', render: tableBytesText }
        ],
        drawCallback: function(settings) {
            insertEmptyTable(settings, this, 5);
        }
    });

    // Auto-refresh every 10 s
    setInterval(function() {
       refreshDashboard();
    }, 10000);
